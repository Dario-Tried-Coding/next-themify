{
  "name": "@dariotriedcoding/next-themify",
  "version": "0.0.5",
  "description": "A Next.js library to acheive custom and easy-to-control themed interfaces.",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc"
  },
  "keywords": [
    "next.js",
    "theming",
    "react",
    "typescript"
  ],
  "author": "dariotriedcoding",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dario-Tried-Coding/next-themify"
  },
  "license": "MIT",
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "printWidth": 400,
    "jsxSingleQuote": true
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^18.3.6",
    "react": "18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "peerDependencies": {
    "@types/react": "^18.3.6",
    "react": "18.3.1"
  }
}