{
  "name": "next-themify",
  "private": true,
  "scripts": {
    "prerelease": "turbo lint test build --filter=@dariotriedcoding/next-themify",
    "release": "pnpm run prerelease && changeset publish",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "prettier": "^3.2.5",
    "turbo": "^2.2.3",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18"
  }
}
